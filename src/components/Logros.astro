---
import { siteConfig } from "../config";
const hasLogros = siteConfig.logros && siteConfig.logros.length > 0;
---

{hasLogros && (
  <section id="logros" class="py-12 md:py-16" style={`background-color: ${siteConfig.accentColor}`}>
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="mb-10 reveal-left">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Logros</h2>
        <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {siteConfig.logros.map((logro, index) => (
          <div class={`reveal stagger-${index + 1} logro-card p-5 rounded-xl bg-white/10 backdrop-blur-sm`}>
            <div class="text-3xl md:text-4xl font-extrabold mb-2" style={`color: ${siteConfig.highlightColor}`}>
              {logro.metric}
            </div>
            <p class="text-sm text-white/90 leading-relaxed">
              {logro.description}
            </p>
            <p class="text-xs font-bold mt-2 text-white/60 uppercase tracking-wider">
              {logro.company}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
