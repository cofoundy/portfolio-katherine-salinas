---
import { siteConfig } from "../config";
---

<!-- Top Accent Bar (solid, high contrast) -->
<div class="w-full h-2 accent-bar"></div>

<section id="hero" class="relative py-12 md:py-16 lg:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Main Hero Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Photo -->
      <div class="order-2 md:order-1 flex justify-center md:justify-start">
        <div class="relative hero-photo">
          <div
            class="absolute -inset-3 rounded-2xl"
            style={`background-color: ${siteConfig.accentColor}; opacity: 0.1`}
          ></div>
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="relative w-56 h-56 md:w-72 md:h-72 lg:w-80 lg:h-80 object-cover rounded-2xl shadow-xl"
            style={`border: 4px solid ${siteConfig.highlightColor}`}
          />
        </div>
      </div>

      <!-- Text Content -->
      <div class="order-1 md:order-2 text-center md:text-left">
        <h1
          class="hero-title text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight"
          style={`color: ${siteConfig.accentColor}`}
        >
          {siteConfig.name}
        </h1>

        <!-- Change #2: Updated professional profile -->
        <p
          class="hero-subtitle text-base md:text-lg font-semibold mt-3 mb-3"
          style={`color: ${siteConfig.highlightColor}`}
        >
          {siteConfig.title}
        </p>

        <div
          class="w-16 h-1 mb-4 mx-auto md:mx-0 rounded-full"
          style={`background-color: ${siteConfig.highlightColor}`}
        ></div>

        <!-- Change #3: Updated tagline -->
        <p class="hero-description text-base md:text-lg text-gray-700 leading-relaxed mb-5 max-w-md mx-auto md:mx-0 font-medium">
          {siteConfig.tagline}
        </p>

        <!-- CTA Button -->
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="hero-cta inline-flex items-center gap-2 px-6 py-3 rounded-full text-white font-bold transition-transform duration-200 hover:scale-105 mb-5"
            style={`background-color: ${siteConfig.highlightColor}`}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Contáctame
          </a>
        )}

        <!-- Social Links -->
        <div class="hero-social flex gap-3 justify-center md:justify-start mb-4">
          {siteConfig.social?.email && (
            <a href={`mailto:${siteConfig.social.email}`} class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Email">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </a>
          )}
          {siteConfig.social?.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="icon-hover w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </div>

        <!-- Change #4: Languages with flags -->
        {siteConfig.languages && siteConfig.languages.length > 0 && (
          <div class="hero-languages flex items-center gap-4 justify-center md:justify-start">
            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
            </svg>
            {siteConfig.languages.map((lang, i) => (
              <span class="flex items-center gap-1 text-sm font-medium text-gray-700">
                <span class="text-lg">{lang.flag}</span>
                <span>{lang.name}</span>
                <span class="text-gray-400 text-xs">({lang.level})</span>
                {i < siteConfig.languages.length - 1 && <span class="text-gray-300 ml-2">|</span>}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Change #5: Replace stats counters with descriptive text block -->
    <div class="mt-10 pt-8 border-t-2 reveal" style={`border-color: ${siteConfig.accentColor}`}>
      <p class="text-base md:text-lg text-gray-700 leading-relaxed text-center max-w-4xl mx-auto">
        <Fragment set:html={siteConfig.heroDescription} />
      </p>
    </div>
  </div>
</section>

<!-- Bottom Accent Bar -->
<div class="w-full h-2 accent-bar"></div>
